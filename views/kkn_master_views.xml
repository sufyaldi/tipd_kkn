<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Faculty Views -->
    <record id="view_kkn_faculty_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.faculty.tree</field>
        <field name="model">tipd_kkn.faculty</field>
        <field name="arch" type="xml">
            <list string="Fakultas">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="action_tipd_kkn_faculty" model="ir.actions.act_window">
        <field name="name">Fakultas</field>
        <field name="res_model">tipd_kkn.faculty</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Study Program Views -->
    <record id="view_kkn_study_program_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.study_program.tree</field>
        <field name="model">tipd_kkn.study_program</field>
        <field name="arch" type="xml">
            <list string="Program Studi">
                <field name="name"/>
                <field name="code"/>
                <field name="faculty_id"/>
            </list>
        </field>
    </record>

    <record id="action_tipd_kkn_study_program" model="ir.actions.act_window">
        <field name="name">Program Studi</field>
        <field name="res_model">tipd_kkn.study_program</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Province Views -->
    <record id="view_kkn_province_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.province.tree</field>
        <field name="model">tipd_kkn.province</field>
        <field name="arch" type="xml">
            <list string="Provinsi" editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_tipd_kkn_province" model="ir.actions.act_window">
        <field name="name">Provinsi</field>
        <field name="res_model">tipd_kkn.province</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Regency Views -->
    <record id="view_kkn_regency_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.regency.tree</field>
        <field name="model">tipd_kkn.regency</field>
        <field name="arch" type="xml">
            <list string="Kabupaten / Kota" editable="bottom">
                <field name="name"/>
                <field name="province_id"/>
            </list>
        </field>
    </record>

    <record id="action_tipd_kkn_regency" model="ir.actions.act_window">
        <field name="name">Kabupaten / Kota</field>
        <field name="res_model">tipd_kkn.regency</field>
        <field name="view_mode">list</field>
    </record>

    <!-- District Views -->
    <record id="view_kkn_district_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.district.tree</field>
        <field name="model">tipd_kkn.district</field>
        <field name="arch" type="xml">
            <list string="Kecamatan" editable="bottom">
                <field name="name"/>
                <field name="regency_id"/>
            </list>
        </field>
    </record>

    <record id="action_tipd_kkn_district" model="ir.actions.act_window">
        <field name="name">Kecamatan</field>
        <field name="res_model">tipd_kkn.district</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Village Views -->
    <record id="view_kkn_village_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.village.tree</field>
        <field name="model">tipd_kkn.village</field>
        <field name="arch" type="xml">
            <list string="Desa / Kelurahan" editable="bottom">
                <field name="name"/>
                <field name="postal_code"/>
                <field name="district_id"/>
            </list>
        </field>
    </record>

    <record id="action_tipd_kkn_village" model="ir.actions.act_window">
        <field name="name">Desa / Kelurahan</field>
        <field name="res_model">tipd_kkn.village</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Grade Component Views -->
    <record id="view_kkn_grade_component_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.grade.component.tree</field>
        <field name="model">tipd_kkn.grade.component</field>
        <field name="arch" type="xml">
            <list string="Komponen Nilai" editable="bottom">
                <field name="name"/>
                <field name="weight"/>
            </list>
        </field>
    </record>

    <record id="action_tipd_kkn_grade_component" model="ir.actions.act_window">
        <field name="name">Komponen Nilai</field>
        <field name="res_model">tipd_kkn.grade.component</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
