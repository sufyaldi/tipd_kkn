<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_tipd_kkn_activity" model="ir.actions.act_window">
        <field name="name">Laporan Kegiatan</field>
        <field name="res_model">tipd_kkn.activity</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="view_kkn_activity_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.activity.tree</field>
        <field name="model">tipd_kkn.activity</field>
        <field name="arch" type="xml">
            <list string="Laporan Kegiatan (LKH)">
                <field name="date"/>
                <field name="name"/>
                <field name="group_id"/>
                <field name="participant_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_kkn_activity_form" model="ir.ui.view">
        <field name="name">tipd_kkn.activity.form</field>
        <field name="model">tipd_kkn.activity</field>
        <field name="arch" type="xml">
            <form string="Laporan Kegiatan">
                <header>
                    <button name="action_submit" string="Submit Laporan" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Setujui (Terbitkan Berita)" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Tolak" type="object" invisible="state != 'submitted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Judul Kegiatan"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="group_id"/>
                        </group>
                        <group>
                            <field name="participant_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Uraian Kegiatan" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter for Comments, Likes & Attachments -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View for Activities to resemble a Social Wall -->
    <record id="view_kkn_activity_kanban" model="ir.ui.view">
        <field name="name">tipd_kkn.activity.kanban</field>
        <field name="model">tipd_kkn.activity</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="date"/>
                <field name="group_id"/>
                <field name="participant_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <ul>
                                    <li>Oleh: <field name="participant_id"/></li>
                                    <li>Kelompok: <field name="group_id"/></li>
                                    <li>Tanggal: <field name="date"/></li>
                                </ul>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'submitted': 'warning', 'approved': 'success', 'rejected': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
