<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kkn_location_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.location.tree</field>
        <field name="model">tipd_kkn.location</field>
        <field name="arch" type="xml">
            <list string="Lokasi Posko">
                <field name="name"/>
                <field name="village_id"/>
                <field name="district_id"/>
                <field name="regency_id"/>
                <field name="province_id"/>
            </list>
        </field>
    </record>

    <record id="view_kkn_location_form" model="ir.ui.view">
        <field name="name">tipd_kkn.location.form</field>
        <field name="model">tipd_kkn.location</field>
        <field name="arch" type="xml">
            <form string="Lokasi Posko">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nama Lokasi / Posko"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="village_id"/>
                            <field name="district_id"/>
                            <field name="regency_id"/>
                            <field name="province_id"/>
                        </group>
                        <group>
                            <field name="address"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tipd_kkn_location" model="ir.actions.act_window">
        <field name="name">Lokasi Posko</field>
        <field name="res_model">tipd_kkn.location</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
