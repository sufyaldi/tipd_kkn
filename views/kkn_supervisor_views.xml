<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kkn_supervisor_tree" model="ir.ui.view">
        <field name="name">tipd_kkn.supervisor.tree</field>
        <field name="model">tipd_kkn.supervisor</field>
        <field name="arch" type="xml">
            <list string="DPL">
                <field name="nip"/>
                <field name="partner_id"/>
                <field name="program_id"/>
            </list>
        </field>
    </record>

    <record id="view_kkn_supervisor_form" model="ir.ui.view">
        <field name="name">tipd_kkn.supervisor.form</field>
        <field name="model">tipd_kkn.supervisor</field>
        <field name="arch" type="xml">
            <form string="Dosen Pembimbing">
                <header>
                    <button name="action_create_user" string="Buat Akun Login" type="object" class="oe_highlight" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="partner_id" placeholder="Pilih Dosen"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="nip"/>
                            <field name="program_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Kelompok Bimbingan" name="groups">
                            <field name="group_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="location_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tipd_kkn_supervisor" model="ir.actions.act_window">
        <field name="name">Dosen Pembimbing</field>
        <field name="res_model">tipd_kkn.supervisor</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
